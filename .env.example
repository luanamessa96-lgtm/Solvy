# SUPABASE: Credenziali del progetto Supabase.
# Trovale su: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL="YOUR_SUPABASE_URL"
VITE_SUPABASE_KEY="YOUR_SUPABASE_ANON_KEY"

# STRIPE: Chiavi del progetto Stripe.
# Trovale su: Stripe Dashboard → Developers → API keys
VITE_STRIPE_PUBLISHABLE_KEY="pk_live_YOUR_PUBLISHABLE_KEY"

# Stripe Price IDs (Stripe Dashboard → Products → copia il Price ID)
VITE_STRIPE_PRICE_MONTHLY="price_YOUR_MONTHLY_PRICE_ID"
VITE_STRIPE_PRICE_YEARLY="price_YOUR_YEARLY_PRICE_ID"

# Queste vanno nelle variabili d'ambiente di Supabase Edge Functions
# (Supabase Dashboard → Edge Functions → Secrets)
# STRIPE_SECRET_KEY=sk_live_YOUR_SECRET_KEY
# STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
